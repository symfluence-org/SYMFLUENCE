#!/usr/bin/env node
/**
 * SYMFLUENCE npm CLI — thin wrapper around the Python CLI.
 *
 * All arguments are forwarded to the Python `symfluence` command so that
 * npm-installed and pip-installed users get identical behaviour.
 *
 * Built-in commands (version, path, help, info) work without Python so
 * that the npm package is self-contained for basic queries.
 *
 * The npm dist/bin directory is prepended to PATH so that the Python CLI's
 * `binary` subcommand can discover the pre-built tools shipped by npm.
 */

const { execFileSync, execSync } = require('child_process');
const path = require('path');
const fs = require('fs');

const pkgRoot = path.join(__dirname, '..');
const distDir = path.join(pkgRoot, 'dist');
const distBinDir = path.join(distDir, 'bin');
const pkgJson = require(path.join(pkgRoot, 'package.json'));

// =========================================================================
// Built-in commands (work without Python)
// =========================================================================

/**
 * Handle commands that can be answered from the npm package alone.
 * @param {string[]} args - CLI arguments
 * @returns {boolean} true if the command was handled
 */
function handleBuiltin(args) {
  const cmd = (args[0] || '').toLowerCase();

  if (cmd === 'version' || cmd === '--version' || cmd === '-v') {
    console.log(pkgJson.version);
    return true;
  }

  if (cmd === 'path') {
    if (fs.existsSync(distBinDir)) {
      console.log(distBinDir);
    } else {
      console.error('Binary directory not found (binaries not yet installed).');
      process.exit(1);
    }
    return true;
  }

  if (cmd === 'help' || cmd === '--help' || cmd === '-h' || !cmd) {
    console.log(`SYMFLUENCE ${pkgJson.version} (npm)\n`);
    console.log('Usage: symfluence <command> [options]\n');
    console.log('Built-in commands:');
    console.log('  help        Show this help message');
    console.log('  version     Print package version');
    console.log('  path        Print binary directory path');
    console.log('  info        Show installation info and detected binaries\n');
    console.log('Python-backed commands (requires pip install symfluence):');
    console.log('  workflow    Run hydrological model workflows');
    console.log('  binary      Manage pre-built model binaries');
    console.log('  ...         All other symfluence CLI commands\n');
    console.log('Documentation: https://github.com/DarriEy/SYMFLUENCE');
    return true;
  }

  if (cmd === 'info') {
    console.log(`SYMFLUENCE ${pkgJson.version} (npm)\n`);
    console.log(`Package root:     ${pkgRoot}`);
    console.log(`Binary directory: ${distBinDir}`);

    if (fs.existsSync(distBinDir)) {
      const bins = fs.readdirSync(distBinDir).filter(f => {
        const full = path.join(distBinDir, f);
        try { return fs.statSync(full).isFile(); } catch { return false; }
      });
      console.log(`Binaries found:   ${bins.length}\n`);
      if (bins.length > 0) {
        bins.forEach(b => console.log(`  - ${b}`));
      }
    } else {
      console.log('Binaries found:   0 (dist/bin not present)\n');
    }

    // Check Python availability
    const cli = findPythonCli();
    if (cli) {
      console.log(`\nPython CLI:       ${cli.exe} ${cli.args.join(' ')}`);
    } else {
      console.log('\nPython CLI:       not found');
      console.log('  Install with: pip install symfluence');
    }

    return true;
  }

  return false;
}

// =========================================================================
// Python forwarding
// =========================================================================

/**
 * Locate the Python symfluence entry-point.
 * Tries, in order: python -m symfluence, python3 -m symfluence, bare `symfluence`
 * on PATH (skipping *this* script to avoid infinite recursion).
 * @returns {{ exe: string, args: string[] } | null}
 */
function findPythonCli() {
  // 1. Try `python -m symfluence` and `python3 -m symfluence`
  for (const py of ['python3', 'python']) {
    try {
      execSync(`${py} -m symfluence --version`, { stdio: 'ignore', timeout: 10000 });
      return { exe: py, args: ['-m', 'symfluence'] };
    } catch {
      // not available
    }
  }

  // 2. Try a bare `symfluence` on PATH that is NOT this wrapper
  const thisScript = fs.realpathSync(__filename);
  try {
    const resolved = execSync('which symfluence', { encoding: 'utf8', timeout: 5000 }).trim();
    if (resolved && fs.realpathSync(resolved) !== thisScript) {
      return { exe: resolved, args: [] };
    }
  } catch {
    // not found
  }

  return null;
}

function main() {
  const userArgs = process.argv.slice(2);

  // Try built-in commands first (no Python required)
  if (handleBuiltin(userArgs)) {
    return;
  }

  // For all other commands, forward to Python CLI
  const cli = findPythonCli();

  if (!cli) {
    console.error(
      'Error: SYMFLUENCE Python package not found.\n\n' +
      'The npm package is a wrapper around the Python CLI.\n' +
      'Install it with:\n\n' +
      '  pip install symfluence\n\n' +
      'Then re-run your command.'
    );
    process.exit(1);
  }

  // Prepend npm dist/bin so the Python CLI can find npm-shipped binaries
  const env = { ...process.env };
  if (fs.existsSync(distBinDir)) {
    env.PATH = `${distBinDir}${path.delimiter}${env.PATH || ''}`;
  }

  try {
    execFileSync(cli.exe, [...cli.args, ...userArgs], { stdio: 'inherit', env });
  } catch (err) {
    process.exit(err.status || 1);
  }
}

main();
